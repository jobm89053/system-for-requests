extends layout

block content
  .container
    h1 Решение обращения
    if appeal
      p Тема: #{appeal.topic}
      p Текст: #{appeal.text}
      p Статус: #{appeal.status}
      p Дата создания: #{appeal.createdAt ? appeal.createdAt.toLocaleDateString() : '—'}
      // Добавьте форму для решения обращения
      form(method="POST", action=`/appeal_solution/${appeal.id}/complete`)
        textarea(name="response", placeholder="Введите решение")
        button(type="submit") Завершить обращение
    else
      p Обращение не найдено
    a(href="/all_appeal") Вернуться к списку обращений